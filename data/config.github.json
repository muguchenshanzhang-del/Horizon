{
  "version": "1.0",
  "ai": {
    "provider": "deepseek",
    "model": "deepseek-chat",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "throttle_sec": 0,
    "analysis_concurrency": 1,
    "enrichment_concurrency": 1
  },
  "email": {
    "enabled": false
  },
  "sources": {
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 50
    },
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 20,
          "min_score": 30
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 20
        },
        {
          "subreddit": "artificial",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 20
        },
        {
          "subreddit": "singularity",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 10
        }
      ],
      "fetch_comments": 3
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "The Verge - AI",
        "url": "https://www.theverge.com/ai-artificial-intelligence/rss/index.xml",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "TechCrunch - AI",
        "url": "https://techcrunch.com/category/artificial-intelligence/feed/",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "ArsTechnica",
        "url": "https://feeds.arstechnica.com/arstechnica/index",
        "enabled": true,
        "category": "tech"
      },
      {
        "name": "Hugging Face Blog",
        "url": "https://huggingface.co/blog/feed.xml",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "Google AI Blog",
        "url": "https://blog.research.google/feed.xml",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "Meta AI Blog",
        "url": "https://ai.meta.com/blog/feed/",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "Anthropic Blog",
        "url": "https://www.anthropic.com/feed.xml",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "OpenAI Blog",
        "url": "https://openai.com/blog/feed.xml",
        "enabled": true,
        "category": "ai"
      }
    ],
    "twitter": {
      "enabled": false
    },
    "github": [
      {
        "type": "repo_releases",
        "owner": "astral-sh",
        "repo": "uv",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "microsoft",
        "repo": "vscode",
        "enabled": true
      }
    ]
  },
  "output": {
    "generate_bilingual": true,
    "languages": [
      "zh",
      "en"
    ],
    "news_per_language": 15,
    "min_score": 5.0,
    "enable_enrichment": true,
    "enable_community_comments": true,
    "enable_background_search": true
  }
}